# =====================================================================
# NextSchoolAI — Variables d'environnement
# Copiez ce fichier en .env et remplissez les valeurs
# =====================================================================

# --- Django ---
SECRET_KEY=changez-moi-en-production-avec-une-longue-cle-aleatoire
DEBUG=True
ALLOWED_HOSTS=127.0.0.1,localhost

# --- Base de données ---
# SQLite (développement) — laisser vide
DB_ENGINE=django.db.backends.sqlite3
DB_NAME=

# MySQL (production)
# DB_ENGINE=django.db.backends.mysql
# DB_NAME=nextschoolai_db
# DB_USER=nextschoolai_user
# DB_PASSWORD=votre_mot_de_passe_mysql
# DB_HOST=localhost
# DB_PORT=3306

# --- Service IA Gemini (Google) ---
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash

# --- Service IA Hugging Face (fallback) ---
HUGGINGFACE_API_KEY=
HUGGINGFACE_MODEL=facebook/bart-large-cnn

# --- Email ---
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=NextSchoolAI <noreply@nextschoolai.cm>
